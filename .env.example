# Healthcare Compliance Agent Configuration

# Application
APP_NAME=HealthcareComplianceAgent
ENVIRONMENT=development  # development, staging, production
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://healthcare:password@localhost:5432/healthcare_dev
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Security
ENCRYPTION_KEY=change-me-in-production-use-32-bytes-base64-encoded
# Generate with: python -c "import secrets; import base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# Authentication
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# HIPAA Compliance
HIPAA_COMPLIANCE_OFFICER_EMAIL=compliance@hospital.com
HIPAA_COMPLIANCE_OFFICER_PHONE=1-800-555-0123
DATA_RETENTION_YEARS=6
BREACH_NOTIFICATION_DAYS=60

# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_SIZE=10000

# Storage
STORAGE_PATH=./data
BACKUP_DIR=./backups
LOG_FILE=./logs/healthcare.log

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Monitoring (Optional)
# SENTRY_DSN=https://your-sentry-dsn
# PROMETHEUS_PORT=9090

# Email (for breach notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifications@hospital.com
# SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM=noreply@hospital.com

# Organization
ORGANIZATION_NAME=Your Hospital
ORGANIZATION_ADDRESS=123 Healthcare Blvd
ORGANIZATION_CITY=City
ORGANIZATION_STATE=ST
ORGANIZATION_ZIP=12345

# PHI Detection
PHI_DETECTION_ENABLED=true
PHI_AUTO_REDACT=true

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PHI_ACCESS=true

# CORS (for API)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true