# Cortex — Railway Safety Compliance Platform Configuration

# Application
APP_NAME=Cortex
ENVIRONMENT=development  # development, staging, production
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://cortex:password@localhost:5432/cortex_rail_dev
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Security
ENCRYPTION_KEY=change-me-in-production-use-32-bytes-base64-encoded
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# Authentication
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Railway Compliance (EN 50128 / EN 50716)
TOOL_CLASS=T2
DEFAULT_SIL_TARGET=SIL2
DATA_RETENTION_YEARS=10
SAFETY_CASE_OFFICER_EMAIL=safety@railway-operator.com
SAFETY_CASE_OFFICER_PHONE=+44-20-1234-5678

# EN 50716 AI Tool Evidence
AI_SYSTEM_VERSION=1.0.0
AI_COMMIT_HASH=unknown
TRAINING_DATA_HASH=unknown
DATA_PROVENANCE=internal_curated
DATA_COLLECTION_START=2025-01-01
DATA_COLLECTION_END=2026-01-01
PREPROCESSING_VERSION=1.0
MODEL_ARCHITECTURE=transformer
TRAINING_METHODOLOGY=supervised_fine_tuning

# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_SIZE=10000

# Storage
STORAGE_PATH=./data
WIKI_PATH=./wiki
RAW_PATH=./raw
BACKUP_DIR=./backups
LOG_FILE=./logs/cortex_rail.log

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Monitoring
# SENTRY_DSN=https://your-sentry-dsn
# PROMETHEUS_PORT=9090

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_ACCESS=true

# T2 Qualification Evidence Output
EVIDENCE_OUTPUT_DIR=./.cortex/evidence
